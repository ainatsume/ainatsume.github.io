---
import BioLayout from "../layouts/BioLayout.astro";
import Icon from "../components/Icon.astro";
import { profile, gameLinks, socials, sprite } from "../data/profile";
---

<BioLayout title={profile.name} description={profile.aboutMe}>
  <div class="wrap">
    <div class="hero">
      {profile.heroImage ? (
        <img src={profile.heroImage} alt="" class="hero-img" />
      ) : (
        <div class="hero-placeholder">
          <span>/public/hero.jpg に画像を置いて<br />profile.ts の heroImage を設定してください</span>
        </div>
      )}
    </div>

    <aside class="sidebar">
      <header class="identity">
        <div class="avatar" aria-hidden={profile.avatarImage ? undefined : "true"}>
          {profile.avatarImage ? (
            <img src={profile.avatarImage} alt={profile.name} />
          ) : (
            <span>{profile.initials}</span>
          )}
        </div>
        <div class="identity-text">
          <div class="name-row">
            <h1 class="name">{profile.name}</h1>
            {profile.langBadge && <span class="lang-badge">{profile.langBadge}</span>}
          </div>
          <div class="socials" aria-label="SNSリンク">
            {socials.map((s) => (
              <a class="social" href={s.url} target="_blank" rel="noopener noreferrer" aria-label={s.label} title={s.label}>
                <Icon name={s.icon} />
              </a>
            ))}
          </div>
        </div>
      </header>

      <section class="panel panel-about">
        <p class="eyebrow"><span class="dash" aria-hidden="true"></span>自己紹介<span class="dash" aria-hidden="true"></span></p>
        <p class="about-text" set:html={profile.aboutMe} />
      </section>

      <section class="panel panel-links">
        <p class="eyebrow"><span class="dash" aria-hidden="true"></span>リンク<span class="dash" aria-hidden="true"></span></p>
        <nav class="game-list" aria-label="リンク一覧">
          {gameLinks.map((link) => (
            <a class="game-row" href={link.url} target="_blank" rel="noopener noreferrer">
              <span class="game-text">
                <span class="game-label">{link.label}</span>
                <span class="game-desc">{link.description}</span>
              </span>
              <span class="game-arrow"><Icon name="arrow" /></span>
            </a>
          ))}
        </nav>
      </section>
    </aside>

    <button type="button" class="corner-sprite" id="corner-sprite" aria-haspopup="dialog" aria-controls="sprite-modal">
      <img src={sprite.image} alt="開く" />
    </button>

    <div class="sprite-modal-overlay" id="sprite-modal-overlay" hidden>
      <div class="sprite-modal" role="dialog" aria-modal="true" id="sprite-modal">
        <img src={sprite.modalImage} alt="" class="sprite-modal-img" />
        <p class="sprite-modal-text">{sprite.caption}</p>
      </div>
    </div>
  </div>
</BioLayout>

<script>
  const trigger = document.getElementById("corner-sprite");
  const overlay = document.getElementById("sprite-modal-overlay");

  function openModal() {
    overlay?.removeAttribute("hidden");
  }

  function closeModal() {
    overlay?.setAttribute("hidden", "");
  }

  trigger?.addEventListener("click", openModal);
  overlay?.addEventListener("click", (e) => {
    if (e.target === overlay) closeModal();
  });
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") closeModal();
  });
</script>

<style>
  .wrap {
    position: relative;
    min-height: 100vh;
    background: var(--ink);
    overflow: hidden;
  }

  .hero {
    position: absolute;
    inset: 0;
    z-index: 0;
    background: var(--ink);
  }

  .hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    position: absolute;
    inset: 0;
  }

  .hero-placeholder {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--ink-faint);
    font-size: 13px;
    line-height: 1.6;
    text-align: center;
    background:
      repeating-linear-gradient(
        45deg,
        rgba(241, 242, 237, 0.04),
        rgba(241, 242, 237, 0.04) 12px,
        transparent 12px,
        transparent 24px
      );
  }

  .sidebar {
    position: relative;
    z-index: 2;
    width: min(46%, 620px);
    min-width: 260px;
    min-height: 100vh;
    color: var(--ink);
    display: flex;
    flex-direction: column;
    gap: 30px;
    padding: 44px 40px 90px 56px;
    background: linear-gradient(
      100deg,
      rgba(250, 243, 241, 0.88) 0%,
      rgba(250, 243, 241, 0.82) 42%,
      rgba(250, 243, 241, 0.55) 68%,
      rgba(250, 243, 241, 0) 96%
    );
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    -webkit-mask-image: linear-gradient(100deg, black 0%, black 55%, transparent 92%);
    mask-image: linear-gradient(100deg, black 0%, black 55%, transparent 92%);
  }

  .identity {
    display: flex;
    align-items: center;
    gap: 18px;
  }

  .avatar {
    width: 74px;
    height: 74px;
    border-radius: 50%;
    background: var(--paper);
    color: var(--ink);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-size: 26px;
    font-weight: 560;
    overflow: hidden;
    flex-shrink: 0;
    border: 1px solid rgba(var(--accent-rgb), 0.35);
    box-shadow: 0 0 0 4px rgba(250, 243, 241, 0.5);
  }

  .avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .identity-text {
    display: flex;
    flex-direction: column;
    gap: 9px;
    min-width: 0;
  }

  .name {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 34px;
    letter-spacing: 0.04em;
    line-height: 1.1;
    color: var(--accent);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .name-row {
    display: flex;
    align-items: baseline;
    gap: 8px;
    flex-wrap: wrap;
  }

  .lang-badge {
    font-family: var(--font-body);
    font-size: 10.5px;
    font-weight: 600;
    letter-spacing: 0.04em;
    color: var(--ink-soft);
    background: rgba(var(--ink-rgb), 0.06);
    border: 1px solid rgba(var(--ink-rgb), 0.12);
    border-radius: 999px;
    padding: 3px 9px;
    white-space: nowrap;
  }

  .socials {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }

  .social {
    width: 15px;
    height: 15px;
    color: var(--ink-soft);
    opacity: 0.85;
    transition: opacity 0.18s ease, transform 0.18s ease, color 0.18s ease;
  }

  .social:hover,
  .social:focus-visible {
    opacity: 1;
    color: var(--accent);
    transform: translateY(-1px);
  }

  .panel {
    padding: 0;
  }

  .eyebrow {
    margin: 0 0 14px;
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-serif);
    font-size: 15px;
    font-weight: 600;
    font-style: italic;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--ink-soft);
  }

  .dash {
    display: inline-block;
    width: 26px;
    height: 1px;
    background: var(--ink-faint);
  }

  .about-text {
    margin: 0;
    font-family: var(--font-body);
    font-size: 14.5px;
    line-height: 1.7;
    color: var(--ink);
    letter-spacing: 0.01em;
    max-width: 34ch;
  }

  .game-list {
    display: flex;
    flex-direction: column;
  }

  .game-row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 14px;
    padding: 13px 0;
    text-decoration: none;
    color: var(--ink);
    border-bottom: 1px solid var(--line);
    transition: padding-left 0.22s ease, color 0.22s ease, border-color 0.22s ease;
  }

  .game-list a:first-child {
    padding-top: 0;
  }

  .game-row:hover,
  .game-row:focus-visible {
    padding-left: 10px;
    color: var(--accent);
    border-color: rgba(var(--accent-rgb), 0.35);
  }

  .game-text {
    display: flex;
    align-items: baseline;
    gap: 12px;
    min-width: 0;
  }

  .game-label {
    font-family: var(--font-serif);
    font-size: 19px;
    font-weight: 600;
    letter-spacing: 0.05em;
    flex-shrink: 0;
  }

  .game-desc {
    font-family: var(--font-body);
    font-size: 12px;
    letter-spacing: 0.03em;
    color: var(--ink-faint);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .game-row:hover .game-desc,
  .game-row:focus-visible .game-desc {
    color: var(--ink-soft);
  }

  .game-arrow {
    width: 13px;
    height: 13px;
    flex-shrink: 0;
    opacity: 0;
    transform: translateX(-4px);
    transition: opacity 0.18s ease, transform 0.18s ease;
  }

  .game-row:hover .game-arrow,
  .game-row:focus-visible .game-arrow {
    opacity: 1;
    transform: translateX(0);
  }

  .corner-sprite {
    position: absolute;
    left: 16px;
    bottom: 0;
    z-index: 5;
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    overflow: visible;
    height: 34vh;
    max-height: 400px;
    min-height: 170px;
    line-height: 0;
    filter: drop-shadow(0 10px 20px rgba(58, 33, 21, 0.32));
  }

  .corner-sprite img {
    height: 100%;
    width: auto;
    display: block;
    transition: transform 0.2s ease;
  }

  .corner-sprite:hover img,
  .corner-sprite:focus-visible img {
    transform: translateY(-8px);
  }

  .sprite-modal-overlay {
    position: fixed;
    inset: 0;
    z-index: 20;
    background: rgba(58, 33, 21, 0.55);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 24px;
  }

  .sprite-modal-overlay[hidden] {
    display: none;
  }

  .sprite-modal {
    position: relative;
    width: 100%;
    max-width: 1000px;
    max-height: 85vh;
    overflow-y: auto;
    background: var(--card);
    border-radius: 18px;
    padding: 20px;
    box-shadow: 0 20px 50px rgba(58, 33, 21, 0.35);
  }

  .sprite-modal-img {
    width: 100%;
    max-width: 1000px;
    height: auto;
    display: block;
    margin: 0 auto;
    border-radius: 4px;
  }

  .sprite-modal-text {
    margin: 20px 0 0;
    font-family: var(--font-serif);
    color: var(--accent);
    font-size: 21px;
    font-style: italic;
    letter-spacing: 0.03em;
    line-height: 1.6;
    white-space: pre-wrap;
    text-align: center;
  }

  @media (max-width: 480px) {
    .corner-sprite {
      left: 8px;
      height: 22vh;
      max-height: 200px;
      min-height: 90px;
    }
    .sidebar {
      padding-bottom: 200px;
    }
  }
</style>
